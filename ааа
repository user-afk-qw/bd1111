CREATE OR REPLACE TRIGGER update_order_time
BEFORE UPDATE ON orders
FOR EACH ROW
BEGIN
    :NEW.time := SYSDATE + 3/24;  -- Москва UTC+3
END update_order_time;



-- Выберите запись для теста
